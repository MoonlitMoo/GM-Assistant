<% provide :title, "Settings — GM Assistant" %>
<% provide :topbar_title, "Settings" %>

<section class="record-shell form-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Preferences</p>
      <h1 class="record-title">Settings</h1>
    </div>

    <%= form_with url: settings_path, method: :patch, scope: nil, class: "resource-form" do |form| %>
      <%= form_return_to_field %>

      <% if current_user.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(current_user.errors.count, "error") %> prevented your settings from being saved:</h2>
          <ul>
            <% current_user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="settings-section">
        <div class="section-heading">
          <h2>Display Defaults</h2>
        </div>

        <div class="resource-form__field">
          <%= form.label :default_transition, "Default transition" %>
          <%= form.select :default_transition,
                          options_for_select(
                            [
                              [ "Crossfade", "crossfade" ],
                              [ "Instant", "instant" ]
                            ],
                            current_user.default_transition
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>

        <div class="resource-form__field resource-form__field--checkbox">
          <label class="resource-form__checkbox">
            <%= form.check_box :default_show_title,
                               {
                                 class: "resource-form__checkbox-input",
                                 checked: current_user.default_show_title
                               },
                               "1",
                               "0" %>
            <span>Show image title on player screen by default</span>
          </label>
        </div>
      </section>

      <section class="settings-section">
        <div class="section-heading">
          <h2>Library &amp; Display</h2>
        </div>

        <div class="resource-form__field">
          <label>Player Screen</label>
        </div>

        <% if current_user.default_transition == "crossfade" %>
          <div class="resource-form__field">
            <%= form.label :crossfade_duration, "Crossfade duration" %>
            <%= form.select :crossfade_duration,
                            options_for_select(
                              [
                                [ "200ms", 200 ],
                                [ "400ms", 400 ],
                                [ "600ms", 600 ],
                                [ "800ms", 800 ],
                                [ "1000ms", 1000 ]
                              ],
                              current_user.crossfade_duration
                            ),
                            {},
                            class: "resource-form__input" %>
          </div>
        <% end %>

        <div class="resource-form__field">
          <%= form.label :image_fit, "Image fit" %>
          <div class="resource-form__field resource-form__field--checkbox">
            <label class="resource-form__checkbox">
              <%= form.radio_button :image_fit, "contain", checked: current_user.image_fit == "contain", class: "resource-form__checkbox-input" %>
              <span>Fit (contain)</span>
            </label>
          </div>
          <div class="resource-form__field resource-form__field--checkbox">
            <label class="resource-form__checkbox">
              <%= form.radio_button :image_fit, "cover", checked: current_user.image_fit == "cover", class: "resource-form__checkbox-input" %>
              <span>Fill (cover)</span>
            </label>
          </div>
        </div>

        <div class="resource-form__field">
          <label>Library</label>
        </div>

        <div class="resource-form__field">
          <%= form.label :dashboard_recent_count, "Dashboard recent images" %>
          <%= form.select :dashboard_recent_count,
                          options_for_select(
                            [
                              [ "3", 3 ],
                              [ "5", 5 ],
                              [ "8", 8 ],
                              [ "10", 10 ]
                            ],
                            current_user.dashboard_recent_count
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>

        <div class="resource-form__field">
          <%= form.label :gm_history_count, "GM history panel" %>
          <%= form.select :gm_history_count,
                          options_for_select(
                            [
                              [ "2", 2 ],
                              [ "3", 3 ],
                              [ "5", 5 ],
                              [ "8", 8 ]
                            ],
                            current_user.gm_history_count
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>
      </section>

      <section class="settings-section">
        <div class="section-heading">
          <h2>Account</h2>
        </div>

        <div class="resource-form__field">
          <%= label_tag :account_email, "Email address" %>
          <%= text_field_tag :account_email,
                             current_user.email_address,
                             class: "resource-form__input",
                             readonly: true,
                             disabled: true %>
        </div>

        <div class="resource-form__actions">
          <%= link_to "Change password",
                      new_user_password_path,
                      class: "fantasy-button fantasy-button--secondary" %>
        </div>
      </section>

      <div class="resource-form__actions">
        <%= form.submit "Save Settings", class: "fantasy-button fantasy-button--primary" %>
        <%= link_to "Cancel", form_cancel_path(campaigns_path), class: "resource-form__cancel" %>
      </div>
    <% end %>
  </div>
</section>
