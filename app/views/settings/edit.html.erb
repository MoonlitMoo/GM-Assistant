<% provide :title, "Settings — GM Assistant" %>
<% provide :topbar_title, "Settings" %>
<% preferences_user = @preferences_user || current_user %>
<% account_user = @account_user || current_user %>

<section class="record-shell form-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Preferences &amp; Account</p>
      <h1 class="record-title">Settings</h1>
    </div>

    <%= form_with url: settings_path, method: :patch, scope: nil, class: "resource-form" do |form| %>
      <%= form_return_to_field %>

      <% if preferences_user.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(preferences_user.errors.count, "error") %> prevented your settings from being saved:</h2>
          <ul>
            <% preferences_user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="settings-section">
        <div class="section-heading">
          <h2>Display Defaults</h2>
        </div>

        <div class="resource-form__field">
          <%= form.label :default_transition, "Default transition" %>
          <%= form.select :default_transition,
                          options_for_select(
                            [
                              [ "Crossfade", "crossfade" ],
                              [ "Instant", "instant" ]
                            ],
                            preferences_user.default_transition
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>

        <div class="resource-form__field resource-form__field--checkbox">
          <label class="resource-form__checkbox">
            <%= form.check_box :default_show_title,
                               {
                                 class: "resource-form__checkbox-input",
                                 checked: preferences_user.default_show_title
                               },
                               "1",
                               "0" %>
            <span>Show image title on player screen by default</span>
          </label>
        </div>
      </section>

      <section class="settings-section">
        <div class="section-heading">
          <h2>Library &amp; Display</h2>
        </div>

        <div class="resource-form__field">
          <label>Player Screen</label>
        </div>

        <% if preferences_user.default_transition == "crossfade" %>
          <div class="resource-form__field">
            <%= form.label :crossfade_duration, "Crossfade duration" %>
            <%= form.select :crossfade_duration,
                            options_for_select(
                              [
                                [ "200ms", 200 ],
                                [ "400ms", 400 ],
                                [ "600ms", 600 ],
                                [ "800ms", 800 ],
                                [ "1000ms", 1000 ]
                              ],
                              preferences_user.crossfade_duration
                            ),
                            {},
                            class: "resource-form__input" %>
          </div>
        <% end %>

        <div class="resource-form__field">
          <%= form.label :image_fit, "Image fit" %>
          <div class="resource-form__field resource-form__field--checkbox">
            <label class="resource-form__checkbox">
              <%= form.radio_button :image_fit, "contain", checked: preferences_user.image_fit == "contain", class: "resource-form__checkbox-input" %>
              <span>Fit (contain)</span>
            </label>
          </div>
          <div class="resource-form__field resource-form__field--checkbox">
            <label class="resource-form__checkbox">
              <%= form.radio_button :image_fit, "cover", checked: preferences_user.image_fit == "cover", class: "resource-form__checkbox-input" %>
              <span>Fill (cover)</span>
            </label>
          </div>
        </div>

        <div class="resource-form__field">
          <label>Library</label>
        </div>

        <div class="resource-form__field">
          <%= form.label :dashboard_recent_count, "Dashboard recent images" %>
          <%= form.select :dashboard_recent_count,
                          options_for_select(
                            [
                              [ "3", 3 ],
                              [ "5", 5 ],
                              [ "8", 8 ],
                              [ "10", 10 ]
                            ],
                            preferences_user.dashboard_recent_count
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>

        <div class="resource-form__field">
          <%= form.label :gm_history_count, "GM history panel" %>
          <%= form.select :gm_history_count,
                          options_for_select(
                            [
                              [ "2", 2 ],
                              [ "3", 3 ],
                              [ "5", 5 ],
                              [ "8", 8 ]
                            ],
                            preferences_user.gm_history_count
                          ),
                          {},
                          class: "resource-form__input" %>
        </div>
      </section>

      <div class="resource-form__actions">
        <%= form.submit "Save Settings", class: "fantasy-button fantasy-button--primary" %>
        <%= link_to "Cancel", form_cancel_path(campaigns_path), class: "resource-form__cancel" %>
      </div>
    <% end %>

    <section class="settings-section">
      <div class="section-heading">
        <h2>Account</h2>
      </div>

      <%= form_for(account_user, as: :user, url: user_registration_path, html: { method: :put, class: "resource-form" }) do |form| %>
        <%= form_return_to_field %>
        <%= render "devise/shared/error_messages", resource: account_user %>

        <div class="resource-form__field">
          <%= form.label :email_address, "Email address" %>
          <%= form.email_field :email_address,
                               required: true,
                               autocomplete: "email",
                               placeholder: "name@example.com",
                               class: "resource-form__input" %>
        </div>

        <% if account_user.respond_to?(:pending_reconfirmation?) && account_user.pending_reconfirmation? %>
          <div class="form-errors">
            <h2>Confirmation pending</h2>
            <ul>
              <li>Currently waiting confirmation for: <%= account_user.unconfirmed_email %></li>
            </ul>
          </div>
        <% end %>

        <div class="resource-form__field">
          <%= form.label :password, "New password" %>
          <p class="auth-field-note">Leave blank if you do not want to change it.</p>
          <% if @minimum_password_length.present? %>
            <p class="auth-field-note"><%= @minimum_password_length %> characters minimum.</p>
          <% end %>
          <%= form.password_field :password,
                                  autocomplete: "new-password",
                                  placeholder: "Choose a new password",
                                  maxlength: 72,
                                  class: "resource-form__input" %>
        </div>

        <div class="resource-form__field">
          <%= form.label :password_confirmation, "Confirm new password" %>
          <%= form.password_field :password_confirmation,
                                  autocomplete: "new-password",
                                  placeholder: "Repeat your new password",
                                  maxlength: 72,
                                  class: "resource-form__input" %>
        </div>

        <div class="resource-form__field">
          <%= form.label :current_password, "Current password" %>
          <p class="auth-field-note">We need your current password to confirm these changes.</p>
          <%= form.password_field :current_password,
                                  required: true,
                                  autocomplete: "current-password",
                                  placeholder: "Enter your current password",
                                  maxlength: 72,
                                  class: "resource-form__input" %>
        </div>

        <div class="resource-form__actions">
          <%= form.submit "Update Account", class: "fantasy-button fantasy-button--primary" %>
          <%= link_to "Cancel", form_cancel_path(campaigns_path), class: "resource-form__cancel" %>
        </div>
      <% end %>
    </section>

    <section class="settings-section">
      <div class="section-heading">
        <h2>Close Account</h2>
      </div>

      <p class="auth-field-note">Unhappy? You can permanently remove your account and sign out everywhere.</p>

      <div class="resource-form__actions">
        <%= button_to "Cancel My Account",
                      user_registration_path,
                      class: "fantasy-button fantasy-button--danger",
                      data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                      method: :delete %>
      </div>
    </section>
  </div>
</section>
