<section class="record-shell form-shell">
  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Album</p>
      <h1 class="record-title"><%= @album.persisted? ? "Edit Album" : "New Album" %></h1>
    </div>

    <% form_options = {
         model: form_model,
         class: "resource-form",
         data: { controller: "submit-shortcut", action: "keydown->submit-shortcut#submit" }
       } %>
    <% form_options[:url] = form_url if local_assigns[:form_url].present? %>

    <%= form_with(**form_options) do |form| %>
      <%= form_return_to_field %>

      <% if @album.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@album.errors.count, "error") %> prevented this album from being saved:</h2>
          <ul>
            <% @album.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="resource-form__field">
        <%= form.label :name %>
        <%= form.text_field :name, class: "resource-form__input", autofocus: true %>
      </div>

      <div class="resource-form__field">
        <%= form.label :description %>
        <%= form.text_area :description, class: "resource-form__input resource-form__textarea", rows: 6 %>
      </div>

      <div class="resource-form__actions">
        <%= form.submit(@album.persisted? ? "Save Album" : "Create Album",
                        class: "fantasy-button fantasy-button--primary") %>
        <%= link_to "Cancel", cancel_path, class: "resource-form__cancel" %>
      </div>
    <% end %>
  </div>
</section>
