<%= content_body_frame do %>
  <section class="record-shell"
           data-controller="player-display"
           data-player-display-campaign-id-value="<%= @campaign.id %>"
           data-player-display-present-url-value="<%= present_campaign_player_display_path(@campaign) %>"
           data-player-display-presenting-image-id-value="<%= @presenting_image_id %>">
    <div class="record-panel">
      <div class="record-header">
        <div class="record-copy">
          <p class="record-kicker">Album</p>
          <h1 class="record-title"><%= @album.name %></h1>

          <% if @album.description.present? %>
            <p class="record-description"><%= @album.description %></p>
          <% end %>

        </div>

        <div class="record-actions">
          <%= link_to "Upload image", new_album_image_path(@album, form_navigation_params), class: "fantasy-button fantasy-button--primary" %>
          <%= link_to "Edit album", edit_album_path(@album, form_navigation_params), class: "fantasy-button" %>
          <%= render "shared/record_delete_button",
                     trigger_label: "Delete album",
                     title: "Delete Album",
                     name: @album.name,
                     description_lines: [
                       "#{pluralize(@images.size, "image")} will be deleted.",
                       "This cannot be undone."
                     ],
                     delete_path: album_path(@album) %>
        </div>
      </div>
    </div>

    <div class="record-panel">
      <div class="section-heading">
        <h2>Images</h2>
        <span><%= pluralize(@images.size, "image") %></span>
      </div>

      <% if @images.any? %>
        <div class="album-grid">
          <% @images.each do |image| %>
            <% presenting_this_image = @presenting_image_id == image.id %>
            <article class="image-card">
              <div class="image-card__thumb-shell">
                <%= link_to image_path(image), class: "image-card__thumb-link" do %>
                  <div class="image-card__thumbnail">
                    <% if image.file.attached? && image.file.representable? %>
                      <%= image_tag image.file.representation(resize_to_fill: [ 480, 360 ]),
                                    alt: image.title,
                                    class: "image-card__preview",
                                    loading: "lazy",
                                    decoding: "async" %>
                    <% else %>
                      <div class="image-card__placeholder">No preview available</div>
                    <% end %>
                  </div>
                <% end %>

                <%= button_tag(presenting_this_image ? "Presenting" : "Present",
                               type: "button",
                               class: class_names("fantasy-button fantasy-button--primary image-card__present-button", { "fantasy-button--active is-active": presenting_this_image }),
                               aria: { label: "Present #{image.title}" },
                               data: {
                                 action: "click->player-display#present",
                                 player_display_image_id: image.id,
                                 player_display_active_label: "Presenting",
                                 player_display_inactive_label: "Present"
                               }) %>
              </div>

              <h3 class="image-card__title">
                <%= link_to image.title, image_path(image), class: "card-title-link" %>
              </h3>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="album-empty-state">
          <p>This album is still waiting for its first illustration.</p>
          <%= link_to "Upload image", new_album_image_path(@album, form_navigation_params), class: "fantasy-button fantasy-button--primary" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
