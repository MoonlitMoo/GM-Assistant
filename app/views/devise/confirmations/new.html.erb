<% provide :title, "Confirm Email — GM Assistant" %>
<% provide :topbar_title, "Confirm email" %>

<section class="record-shell form-shell auth-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Account Confirmation</p>
      <h1 class="record-title">Resend confirmation instructions</h1>
      <p class="record-description auth-description">Need another confirmation email? Enter your address and we&apos;ll send a fresh link.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_confirmation_path, html: { method: :post, class: "resource-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="resource-form__field">
        <%= f.label :email_address, "Email address" %>
        <%= f.email_field :email_address,
                          autofocus: true,
                          autocomplete: "email",
                          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email_address),
                          class: "resource-form__input" %>
      </div>

      <div class="resource-form__actions">
        <%= f.submit "Resend confirmation instructions", class: "fantasy-button fantasy-button--primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
