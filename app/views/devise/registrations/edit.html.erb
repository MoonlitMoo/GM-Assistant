<% provide :title, "Account Settings — GM Assistant" %>
<% provide :topbar_title, "Account" %>

<section class="record-shell form-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Account</p>
      <h1 class="record-title">Update your account</h1>
      <p class="record-description auth-description">Change your email address or password for GM Assistant.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_registration_path, html: { method: :put, class: "resource-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="resource-form__field">
        <%= f.label :email_address, "Email address" %>
        <%= f.email_field :email_address,
                          autofocus: true,
                          autocomplete: "email",
                          class: "resource-form__input" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="form-errors">
          <h2>Confirmation pending</h2>
          <ul>
            <li>Currently waiting confirmation for: <%= resource.unconfirmed_email %></li>
          </ul>
        </div>
      <% end %>

      <div class="resource-form__field">
        <%= f.label :password, "New password" %>
        <p class="auth-field-note">Leave blank if you do not want to change it.</p>
        <% if @minimum_password_length %>
          <p class="auth-field-note"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             maxlength: 72,
                             class: "resource-form__input" %>
      </div>

      <div class="resource-form__field">
        <%= f.label :password_confirmation, "Confirm new password" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             maxlength: 72,
                             class: "resource-form__input" %>
      </div>

      <div class="resource-form__field">
        <%= f.label :current_password, "Current password" %>
        <p class="auth-field-note">We need your current password to confirm these changes.</p>
        <%= f.password_field :current_password,
                             autocomplete: "current-password",
                             maxlength: 72,
                             class: "resource-form__input" %>
      </div>

      <div class="resource-form__actions">
        <%= f.submit "Update account", class: "fantasy-button fantasy-button--primary" %>
      </div>
    <% end %>

    <section class="settings-section">
      <div class="section-heading">
        <h2>Close account</h2>
      </div>

      <p class="auth-field-note">Unhappy? You can permanently remove your account and sign out everywhere.</p>

      <div class="resource-form__actions">
        <%= button_to "Cancel my account",
                      user_registration_path,
                      class: "fantasy-button fantasy-button--danger",
                      data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                      method: :delete %>
        <%= link_to "Back", form_cancel_path(campaigns_path), class: "resource-form__cancel" %>
      </div>
    </section>
  </div>
</section>
