<% provide :title, "Create Account — GM Assistant" %>
<% provide :topbar_title, "Create account" %>

<section class="record-shell form-shell auth-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">New Account</p>
      <h1 class="record-title">Join the archive</h1>
      <p class="record-description auth-description">Create your GM Assistant account and start organizing campaigns, images, and player displays.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_registration_path, html: { class: "resource-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="resource-form__field">
        <%= f.label :email_address, "Email address" %>
        <%= f.email_field :email_address,
                          required: true,
                          autofocus: true,
                          autocomplete: "email",
                          placeholder: "name@example.com",
                          value: resource.email_address.presence || params.dig(resource_name, :email_address),
                          class: "resource-form__input" %>
      </div>

      <div class="resource-form__field">
        <%= f.label :password, "Password" %>
        <% if @minimum_password_length %>
          <p class="auth-field-note"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
        <%= f.password_field :password,
                             required: true,
                             autocomplete: "new-password",
                             placeholder: "Choose a strong password",
                             maxlength: 72,
                             class: "resource-form__input" %>
      </div>

      <div class="resource-form__field">
        <%= f.label :password_confirmation, "Confirm password" %>
        <%= f.password_field :password_confirmation,
                             required: true,
                             autocomplete: "new-password",
                             placeholder: "Repeat your password",
                             maxlength: 72,
                             class: "resource-form__input" %>
      </div>

      <div class="resource-form__actions">
        <%= f.submit "Create account", class: "fantasy-button fantasy-button--primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
