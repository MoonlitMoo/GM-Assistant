<% provide :title, "Reset Password — GM Assistant" %>
<% provide :topbar_title, "Sign in" %>

<section class="record-shell form-shell auth-shell">
  <%= render "shared/flash" %>

  <div class="record-panel form-panel">
    <div class="form-panel__header">
      <p class="record-kicker">Account Recovery</p>
      <h1 class="record-title">Forgot your password?</h1>
      <p class="record-description auth-description">Enter your email address and we&apos;ll send you a reset link.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_password_path, html: { method: :post, class: "resource-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="resource-form__field">
        <%= f.label :email_address, "Email address" %>
        <%= f.email_field :email_address,
                          required: true,
                          autofocus: true,
                          autocomplete: "username",
                          placeholder: "Enter your email address",
                          value: resource.email_address.presence || params.dig(resource_name, :email_address),
                          class: "resource-form__input" %>
      </div>

      <div class="resource-form__actions">
        <%= f.submit "Send reset instructions", class: "fantasy-button fantasy-button--primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
