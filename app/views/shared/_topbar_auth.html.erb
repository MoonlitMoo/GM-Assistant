<% if user_signed_in? %>
  <%= button_to destroy_user_session_path,
                method: :delete,
                class: "topbar-auth-button",
                form_class: "topbar-auth-form" do %>
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M15 7.5V5.8a1.8 1.8 0 0 0-1.8-1.8H6.8A1.8 1.8 0 0 0 5 5.8v12.4A1.8 1.8 0 0 0 6.8 20h6.4a1.8 1.8 0 0 0 1.8-1.8v-1.7" />
      <path d="M10 12h9" />
      <path d="m16 8 4 4-4 4" />
    </svg>
    <span>Sign out</span>
  <% end %>

  <%= render "shared/settings_icon" %>
<% elsif !current_page?(new_user_session_path) %>
  <%= link_to new_user_session_path, class: "topbar-auth-link", aria: { label: "Sign in" } do %>
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M15 7.5V5.8a1.8 1.8 0 0 0-1.8-1.8H6.8A1.8 1.8 0 0 0 5 5.8v12.4A1.8 1.8 0 0 0 6.8 20h6.4a1.8 1.8 0 0 0 1.8-1.8v-1.7" />
      <path d="M20 12h-9" />
      <path d="m14 8-4 4 4 4" />
    </svg>
    <span>Sign in</span>
  <% end %>
<% end %>
