<dialog
  class="tree-delete-modal"
  data-record-delete-modal-target="modal"
  data-action="click->record-delete-modal#backdropClose cancel->record-delete-modal#handleCancel"
  role="presentation"
>
  <div
    class="tree-delete-modal__card"
    data-record-delete-modal-target="card"
    role="dialog"
    aria-modal="true"
    aria-labelledby="record-delete-modal-title"
    tabindex="-1"
  >
    <p class="tree-delete-modal__kicker">Archive Warning</p>
    <h2 id="record-delete-modal-title" class="tree-delete-modal__title" data-record-delete-modal-target="title">Delete Item</h2>
    <p class="tree-delete-modal__name" data-record-delete-modal-target="name" hidden></p>

    <div class="tree-delete-modal__body" data-record-delete-modal-target="body"></div>

    <p class="tree-delete-modal__error" data-record-delete-modal-target="error" role="alert" hidden></p>

    <div class="tree-delete-modal__actions">
      <button type="button" class="fantasy-button" data-action="record-delete-modal#close">
        Cancel
      </button>
      <button
        type="button"
        class="fantasy-button fantasy-button--danger tree-delete-modal__delete"
        data-record-delete-modal-target="confirm"
        data-action="record-delete-modal#confirmDelete"
      >
        Delete
      </button>
    </div>
  </div>
</dialog>
