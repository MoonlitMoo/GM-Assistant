<article class="library-card library-card--folder">
  <p class="library-card__kicker">Folder</p>
  <h3 class="library-card__title">
    <%= link_to folder.name, folder_path(folder) %>
  </h3>
  <p class="library-card__meta">
    <%= pluralize(folder.child_folders.size, "child folder") %> ·
    <%= pluralize(folder.albums.size, "album") %>
  </p>
</article>
