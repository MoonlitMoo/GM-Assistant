<!DOCTYPE html>
<html>
  <head>
    <title><%= @campaign.name %> — GM Assistant</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>
  </head>
  <% standalone_layout = content_for?(:standalone_campaign_layout) %>
  <body>

    <!-- Top bar -->
    <div id="top-bar">
      <%= link_to "⚔ GM Assistant", campaigns_path %>
      <span><%= content_for?(:topbar_title) ? yield(:topbar_title) : @campaign.name %></span>
      <span class="topbar-actions">
        <%= render "player_displays/topbar_status", player_display: @campaign.player_display %>
        <span class="topbar-icon">⚙</span>
      </span>
    </div>

    <% if standalone_layout %>
      <main class="standalone-main standalone-main--campaign">
        <%= yield %>
      </main>
    <% else %>
      <div id="main-wrapper">

        <!-- Sidebar -->
        <div id="sidebar">
          <div id="campaign-tree" data-tree-url="<%= tree_campaign_path(@campaign) %>"></div>
          <details id="gm-panel" class="gm-panel">
            <summary>
              <%= render "player_displays/gm_panel_header", player_display: @campaign.player_display %>
            </summary>
            <%= render "player_displays/gm_status", player_display: @campaign.player_display %>
          </details>
          <script>
            (() => {
              function syncGmPanelState() {
                const gmPanel = document.getElementById("gm-panel")
                if (!gmPanel || gmPanel.dataset.stateBound === "true") return

                gmPanel.open = sessionStorage.getItem("gm-panel-open") === "true"
                gmPanel.addEventListener("toggle", () => {
                  sessionStorage.setItem("gm-panel-open", gmPanel.open ? "true" : "false")
                })
                gmPanel.dataset.stateBound = "true"
              }

              document.addEventListener("turbo:load", syncGmPanelState)
              document.addEventListener("DOMContentLoaded", syncGmPanelState)
              syncGmPanelState()
            })()
          </script>
        </div>

        <!-- Main content -->
          <div id="main-content">
          <div id="main-content"
               data-controller="content-panel"
               data-action="turbo:frame-load->content-panel#syncBreadcrumbs">
            <div id="breadcrumbs" data-content-panel-target="breadcrumbs">
              <%= render "shared/breadcrumbs", breadcrumbs: breadcrumbs %>
            </div>
            <% if turbo_frame_request? %>
              <%= yield %>
            <% else %>
              <%= turbo_frame_tag "content-body", **content_body_frame_options do %>
                <%= breadcrumbs_payload_tag %>
                <%= yield %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

  </body>
</html>
