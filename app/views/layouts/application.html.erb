<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "GM Assistant" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gm Assistant">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application" %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>

  </head>

  <body>
    <div id="top-bar">
      <%= link_to "⚔ GM Assistant", campaigns_path %>
      <span><%= content_for?(:topbar_title) ? yield(:topbar_title) : "Campaigns" %></span>
      <span class="topbar-actions">
        <%= render "shared/settings_icon" %>
      </span>
    </div>

    <main class="standalone-main">
      <%= yield %>
    </main>
  </body>
</html>
